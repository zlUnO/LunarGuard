<Window x:Class="LunarGuard.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LunarGuard"
        Width="960" Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True">

    <Grid Margin="20">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#001034" Opacity="0.5"/>
        </Grid.Effect>

        <Border CornerRadius="20" Background="#E003081E">
            <Border.Effect>
                <BlurEffect Radius="30"/>
            </Border.Effect>
        </Border>

        <Border x:Name="MainContainer" CornerRadius="20" Background="#F0030B1C">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== SIDEBAR ===== -->
                <Border Grid.Column="0" CornerRadius="20,0,0,20"
                        Background="#80000000"
                        BorderBrush="#25006EFF" BorderThickness="0,0,1,0">
                    <Grid Margin="0,12,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,8,0,20">
                            <Border Width="56" Height="56" CornerRadius="28"
                                    Background="Transparent" BorderBrush="#30006EFF" BorderThickness="1"
                                    HorizontalAlignment="Center" Margin="0,0,0,6">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#006EFF" Opacity="0.3"/>
                                </Border.Effect>
                                <TextBlock Text="🛡" FontSize="26" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="LunarGuard" FontSize="18" FontWeight="SemiBold"
                                       Foreground="#E2F0FD" HorizontalAlignment="Center"/>
                            <TextBlock Text="v2.0.0" FontSize="11" Foreground="#5A7FA4CF"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Tab buttons -->
                        <StackPanel Grid.Row="1" Margin="6,0">
                            <RadioButton x:Name="TabHome" GroupName="Nav" IsChecked="True"
                                         Style="{StaticResource NavItemStyle}" Content="Главная"
                                         />
                            <RadioButton x:Name="TabFaq" GroupName="Nav" Style="{StaticResource NavItemStyle}"
                                         Content="FAQ" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="10,0,10,8">
                            <Button x:Name="UpdateBtn" Style="{StaticResource UpdateBtnStyle}"
                                    Click="CheckUpdates_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Проверить обновления" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="3" Margin="10,4,10,0" Padding="10,10"
                                CornerRadius="10" Background="#0D00FF87"
                                BorderBrush="#2200FF87" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#00FF87" Margin="0,0,6,2"
                                             VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#00FF87"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="Активна" Foreground="#00FF87" FontSize="12"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="Защита готова" Foreground="#7FA4CF" FontSize="10"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ===== MAIN CONTENT ===== -->
                <Grid Grid.Column="1" Margin="20,16,20,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="PageTitle"
                                   Text="Главная" FontSize="22" FontWeight="Medium"
                                   Foreground="#E2F0FD"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="MinimizeBtn" Style="{StaticResource WinCtrlBtn}" Content="─"
                                    Click="Minimize_Click" ToolTip="Свернуть"/>
                            <Button x:Name="MaximizeBtn" Style="{StaticResource WinCtrlBtn}" Content="□"
                                    Click="Maximize_Click" ToolTip="Развернуть" Margin="6,0,0,0"/>
                            <Button x:Name="CloseBtn" Style="{StaticResource WinCtrlBtn}" Content="✕"
                                    Click="Close_Click" ToolTip="Закрыть" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== HOME TAB ===== -->
                    <Grid x:Name="HomePanel" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- File selection row -->
                        <Border Grid.Row="0" CornerRadius="12" Background="#18061A3A"
                                BorderBrush="#1A006EFF" BorderThickness="1" Padding="16,14"
                                Height="74">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                                        Background="#15006EFF" BorderBrush="#30006EFF" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="📂" FontSize="20" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="FilePathText"
                                               Text="Нажмите «Выбрать файл» чтобы открыть .lua"
                                               FontSize="13" Foreground="#7FA4CF" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="FileSizeText" Text="" FontSize="11"
                                               Foreground="#5A7FA4CF" Margin="0,1,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="2" x:Name="BrowseBtn"
                                        Style="{StaticResource AccentBtnStyle}" Content="Выбрать файл"
                                        Click="BrowseFile_Click"/>
                            </Grid>
                        </Border>

                        <!-- Settings panel (visible when file selected + processing ready) -->
                        <ScrollViewer Grid.Row="1" Margin="0,10,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="SettingsPanel" IsEnabled="False">
                                <TextBlock Text="Настройки обфускации"
                                           FontSize="15" FontWeight="SemiBold" Foreground="#E2F0FD"
                                           Margin="0,0,0,10"/>

                                <!-- Rename Variables -->
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkRename" IsChecked="True"
                                                  Style="{StaticResource SettingCheckbox}"
                                                  />
                                        <StackPanel Grid.Column="1" Margin="0,0,0,0">
                                            <TextBlock Text="Переименование переменных" FontSize="13"
                                                       Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                            <TextBlock Text="Заменяет имена переменных на случайные" FontSize="11"
                                                       Foreground="#7FA4CF" Margin="0,1,0,0"/>
                                            <Border x:Name="RenamePrefixRow" CornerRadius="8"
                                                    Background="#0AFFFFFF" BorderBrush="#15006EFF" BorderThickness="1"
                                                    Padding="8,6" Margin="0,6,0,0">
                                                <TextBox x:Name="TxtRenamePrefix" Text=""
                                                         Style="{StaticResource DarkTextBox}"
                                                         FontFamily="Consolas" FontSize="12"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Encrypt Strings -->
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkEncrypt" IsChecked="True"
                                                  Style="{StaticResource SettingCheckbox}"
                                                  />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Шифрование строк" FontSize="13"
                                                       Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                            <TextBlock Text="Шифрует строковые литералы в коде" FontSize="11"
                                                       Foreground="#7FA4CF" Margin="0,1,0,0"/>
                                            <Border x:Name="StringKeyRow" CornerRadius="8"
                                                    Background="#0AFFFFFF" BorderBrush="#15006EFF" BorderThickness="1"
                                                    Padding="8,6" Margin="0,6,0,0">
                                                <TextBox x:Name="TxtStringKey" Text="lx9zq4k7"
                                                         Style="{StaticResource DarkTextBox}"
                                                         FontFamily="Consolas" FontSize="12"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Encode Numbers -->
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkEncodeNumbers" IsChecked="True"
                                                  Style="{StaticResource SettingCheckbox}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Кодирование чисел" FontSize="13"
                                                       Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                            <TextBlock Text="Маскирует числовые значения" FontSize="11"
                                                       Foreground="#7FA4CF" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Dead Code -->
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkDeadCode" IsChecked="True"
                                                  Style="{StaticResource SettingCheckbox}"
                                                  />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Инъекция мёртвого кода" FontSize="13"
                                                       Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                            <TextBlock Text="Добавляет невыполняемые блоки кода" FontSize="11"
                                                       Foreground="#7FA4CF" Margin="0,1,0,0"/>
                                            <Border x:Name="DeadCodeRow" CornerRadius="8"
                                                    Background="#0AFFFFFF" BorderBrush="#15006EFF" BorderThickness="1"
                                                    Padding="8,6" Margin="0,6,0,0">
                                                <TextBox x:Name="TxtDeadCodeBlocks" Text="5"
                                                         Style="{StaticResource DarkTextBox}"
                                                         FontFamily="Consolas" FontSize="12"
                                                         Width="60" HorizontalAlignment="Left"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Control Flow -->
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkControlFlow" IsChecked="True"
                                                  Style="{StaticResource SettingCheckbox}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Запутывание потока управления" FontSize="13"
                                                       Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                            <TextBlock Text="Изменяет структуру циклов и условий" FontSize="11"
                                                       Foreground="#7FA4CF" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Split Expressions -->
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkSplitExpr" IsChecked="True"
                                                  Style="{StaticResource SettingCheckbox}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Разделение выражений" FontSize="13"
                                                       Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                            <TextBlock Text="Дробит сложные выражения на части" FontSize="11"
                                                       Foreground="#7FA4CF" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Anti Debug -->
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkAntiDebug" IsChecked="True"
                                                  Style="{StaticResource SettingCheckbox}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Анти-отладка" FontSize="13"
                                                       Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                            <TextBlock Text="Добавляет защиту от отладчиков" FontSize="11"
                                                       Foreground="#7FA4CF" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Virtualize -->
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkVirtualize" IsChecked="True"
                                                  Style="{StaticResource SettingCheckbox}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Виртуализация" FontSize="13"
                                                       Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                            <TextBlock Text="Преобразует код в виртуальную инструкцию" FontSize="11"
                                                       Foreground="#7FA4CF" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Output and run -->
                                <Border CornerRadius="12" Background="#18061A3A"
                                        BorderBrush="#1A006EFF" BorderThickness="1"
                                        Padding="14,12" Margin="0,6,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Выходной файл" FontSize="12"
                                                       Foreground="#7FA4CF" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="OutputPathText"
                                                       Text="не выбран — будет создан рядом с исходным"
                                                       FontSize="12" Foreground="#5A7FA4CF"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" x:Name="RunBtn"
                                                Style="{StaticResource RunBtnStyle}"
                                                Content="Запустить обработку"
                                                Click="Run_Click"
                                                IsEnabled="False"/>
                                    </Grid>
                                </Border>

                                <!-- Progress -->
                                <Border x:Name="ProgressPanel" CornerRadius="12"
                                        Background="#18061A3A" BorderBrush="#1A006EFF" BorderThickness="1"
                                        Padding="14,12" Margin="0,0,0,6" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="ProgressStatusText" Text="Обработка..."
                                                       FontSize="13" Foreground="#E2F0FD"/>
                                            <TextBlock Grid.Column="1" x:Name="ProgressPercentText" Text="0%"
                                                       FontSize="13" Foreground="#00D2FF" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Border Grid.Row="1" Height="6" CornerRadius="3" Background="#1AFFFFFF"
                                                Margin="0,8,0,0">
                                            <Border x:Name="ProgressFill" Width="0" Height="6"
                                                    CornerRadius="3" HorizontalAlignment="Left">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#00D2FF" Offset="0"/>
                                                        <GradientStop Color="#0072FF" Offset="0.5"/>
                                                        <GradientStop Color="#00FF87" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#00D2FF" Opacity="0.6"/>
                                                </Border.Effect>
                                            </Border>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ===== FAQ TAB ===== -->
                    <Grid x:Name="FaqPanel" Grid.Row="1" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Настройки обфускации LunarGuard"
                                           FontSize="18" FontWeight="SemiBold" Foreground="#E2F0FD"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Описание каждой доступной опции"
                                           FontSize="12" Foreground="#7FA4CF" Margin="0,0,0,16"/>

                                <Border Style="{StaticResource FaqCard}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                                                    Background="#1A006EFF" BorderBrush="#30006EFF" BorderThickness="1"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="✏" FontSize="14" Foreground="#00D2FF"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Переименование переменных" FontSize="14"
                                                           Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                                <TextBlock Text="Заменяет все локальные и глобальные имена переменных на случайные строки. Это делает код нечитаемым для человека, но не влияет на выполнение." FontSize="12"
                                                           Foreground="#7FA4CF" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border CornerRadius="6" Background="#0AFFFFFF" Padding="10,8" Margin="0,10,0,0">
                                            <TextBlock Text="Совет: Используйте кастомный префикс (например _0x или _) чтобы сделать переименованные переменные более узнаваемыми. По умолчанию генерируется случайный префикс." FontSize="11"
                                                       Foreground="#5A7FA4CF" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource FaqCard}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                                                    Background="#1A006EFF" BorderBrush="#30006EFF" BorderThickness="1"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="🔑" FontSize="14" Foreground="#00D2FF"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Шифрование строк" FontSize="14"
                                                           Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                                <TextBlock Text="Шифрует все строковые литералы (текст в кавычках) с использованием XOR-шифрования. Строки расшифровываются во время выполнения. Защищает чувствительные строки от статического анализа." FontSize="12"
                                                           Foreground="#7FA4CF" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border CornerRadius="6" Background="#0AFFFFFF" Padding="10,8" Margin="0,10,0,0">
                                            <TextBlock Text="Совет: Укажите свой ключ шифрования. Чем длиннее и сложнее ключ, тем надёжнее защита. Рекомендуется 8+ символов." FontSize="11"
                                                       Foreground="#5A7FA4CF" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource FaqCard}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                                                    Background="#1A006EFF" BorderBrush="#30006EFF" BorderThickness="1"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="🔢" FontSize="14" Foreground="#00D2FF"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Кодирование чисел" FontSize="14"
                                                           Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                                <TextBlock Text="Маскирует числовые значения через математические преобразования. Например, число 5 может стать (21 - 16). Затрудняет поиск важных констант в коде." FontSize="12"
                                                           Foreground="#7FA4CF" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource FaqCard}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                                                    Background="#1A006EFF" BorderBrush="#30006EFF" BorderThickness="1"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="💀" FontSize="14" Foreground="#00D2FF"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Инъекция мёртвого кода" FontSize="14"
                                                           Foreground="#E2F0FD" FontWeight="SemiBold"/>
                                                <TextBlock Text="Добавляет в код блоки, которые никогда не выполняются. Увеличивает размер файла и усложняет статический анализ, не влияя на логику." FontSize="12"
                                                           Foreground="#7FA4CF" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border CornerRadius="6" Background="#0AFFFFFF" Padding="10,8" Margin="0,10,0,0">
                                            <TextBlock Text="Совет: Количество блоков влияет на размер выходного файла. Значение 5-10 хорошо для баланса размера и защиты." FontSize="11"
                                                       Foreground="#5A7FA4CF" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource FaqCard}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                                                    Background="#1A006EFF" BorderBrush="#30006EFF" BorderThickness="1"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="🌀" FontSize="14" Foreground="#00D2FF"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Запутывание потока управления" FontSize="14"
                                                           Foreground="#E2F0FD" FontWeight="SemiBold"/>
